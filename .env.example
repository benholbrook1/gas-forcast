## Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# Optional: Gemini overload retries (exponential backoff + jitter)
# GEMINI_MAX_RETRIES=6
# GEMINI_RETRY_BASE_SECONDS=4
# GEMINI_RETRY_MAX_SECONDS=90

## Recipients — required: one row per line: phone, city [, compact|detailed]
# Optional third field selects SMS layout for that row; if omitted, SMS_TEMPLATE is used.
# Same (city + template) → one Gemini call; all numbers in that group get the same SMS.
RECIPIENTS="226-792-8781, waterloo, compact
324-543-2356, burlington, detailed
324-352-2356, waterloo"
# Or: RECIPIENTS_FILE=recipients.txt

REGION=Ontario, Canada
TIMEZONE=America/Toronto

## Twilio (SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+15551234567

## Logging
LOG_DIR=logs

## Flags
DEBUG=false
DRY_RUN=true
# GitHub Actions schedule only: skip unless local wall time is ~4:45 PM (TIMEZONE). Set to bypass.
# FORCE_FORECAST=true

## Default SMS template when a recipient line has no third field — compact or detailed
SMS_TEMPLATE=compact
# Max length for compact only (0 = no cap). Detailed uses SMS_MAX_LEN_DETAILED.
SMS_MAX_LEN=122
# Detailed: default 0 = full multiline message (may use multiple SMS segments). Set e.g. 900 to hard-cap.
SMS_MAX_LEN_DETAILED=0
