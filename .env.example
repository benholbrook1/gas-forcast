## Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

## Location
# Use one of these:
TARGET_CITY=waterloo
# TARGET_CITIES=waterloo,toronto,ottawa
REGION=Ontario, Canada
TIMEZONE=America/Toronto

## Twilio (SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+15551234567
# Use one of these:
TWILIO_TO_NUMBER=+15557654321
# TWILIO_TO_NUMBERS=+15557654321,+15559876543

## Logging
LOG_DIR=logs

## Flags
DEBUG=false
DRY_RUN=true # When true, prints SMS to stdout and does not send.

## SMS formatting
SMS_TEMPLATE=detailed # "compact" (price + recommendation) or "detailed" (full briefing)
SMS_MAX_LEN=122 # Max SMS body length (set 0 to disable truncation)

